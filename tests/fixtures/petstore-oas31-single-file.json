{
  "openapi": "3.1.0",
  "info": {
    "title": "Swagger Petstore - OpenAPI 3.1 (Single File)",
    "description": "A single-file adaptation of the Swagger Petstore 3.1 spec for E2E testing. Uses only local $refs so Postman Spec Hub can resolve the document without a multi-file resolver.",
    "termsOfService": "https://swagger.io/terms/",
    "contact": {
      "name": "Swagger Team",
      "email": "apiteam@swagger.io"
    },
    "license": {
      "name": "Apache 2.0",
      "url": "https://www.apache.org/licenses/LICENSE-2.0.html"
    },
    "version": "1.0.10",
    "summary": "Pet Store 3.1"
  },
  "servers": [
    { "url": "/api/v31", "description": "Petstore 3.1 server" }
  ],
  "tags": [
    {
      "name": "pet",
      "description": "Everything about your Pets"
    }
  ],
  "paths": {
    "/pet": {
      "put": {
        "tags": ["pet"],
        "summary": "Update an existing pet.",
        "description": "Update an existing pet by Id.",
        "operationId": "updatePet",
        "requestBody": {
          "description": "Pet object that needs to be updated in the store",
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/Pet" }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful operation",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Pet" }
              }
            }
          },
          "400": { "description": "Invalid ID supplied" },
          "404": { "description": "Pet not found" },
          "405": { "description": "Validation exception" },
          "500": { "description": "Unexpected error" }
        },
        "security": [{ "petstore_auth": ["write:pets", "read:pets"] }]
      },
      "post": {
        "tags": ["pet"],
        "summary": "Add a new pet to the store.",
        "description": "Add a new pet to the store.",
        "operationId": "addPet",
        "requestBody": {
          "description": "Create a new pet in the store",
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/Pet" }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful operation",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Pet" }
              }
            }
          },
          "405": { "description": "Invalid input" },
          "500": { "description": "Unexpected error" }
        },
        "security": [{ "petstore_auth": ["write:pets", "read:pets"] }]
      }
    },
    "/pet/{petId}": {
      "get": {
        "tags": ["pet"],
        "summary": "Find pet by its identifier.",
        "description": "Returns a pet when 0 < ID <= 10. ID > 10 or non-integers will simulate API error conditions.",
        "operationId": "getPetById",
        "parameters": [
          {
            "name": "petId",
            "in": "path",
            "description": "ID of pet that needs to be fetched",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64",
              "exclusiveMaximum": 10,
              "exclusiveMinimum": 1
            }
          }
        ],
        "responses": {
          "200": {
            "description": "The pet",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Pet" }
              }
            }
          },
          "400": { "description": "Invalid ID supplied" },
          "404": { "description": "Pet not found" },
          "500": { "description": "Unexpected error" }
        },
        "security": [
          { "petstore_auth": ["write:pets", "read:pets"] },
          { "api_key": [] }
        ]
      }
    }
  },
  "webhooks": {
    "newPet": {
      "post": {
        "summary": "New pet webhook",
        "operationId": "newPetWebhook",
        "requestBody": {
          "description": "Information about a new pet in the system",
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/Pet" }
            }
          }
        },
        "responses": {
          "200": { "description": "Return a 200 status to indicate the data was received successfully" },
          "500": { "description": "Unexpected error" }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Category": {
        "description": "Pet category",
        "properties": {
          "id": { "type": "integer", "format": "int64" },
          "name": { "type": "string" }
        },
        "xml": { "name": "Category" }
      },
      "Tag": {
        "description": "Pet tag",
        "properties": {
          "id": { "type": "integer", "format": "int64" },
          "name": { "type": "string" }
        },
        "xml": { "name": "Tag" }
      },
      "Pet": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "description": "A pet in the store",
        "required": ["name", "photoUrls"],
        "properties": {
          "id": { "type": "integer", "format": "int64" },
          "category": { "$ref": "#/components/schemas/Category" },
          "name": {
            "type": "string",
            "examples": ["doggie"]
          },
          "photoUrls": {
            "type": "array",
            "items": { "type": "string" },
            "xml": { "wrapped": true }
          },
          "tags": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Tag" },
            "xml": { "wrapped": true }
          },
          "status": {
            "type": "string",
            "description": "pet status in the store",
            "enum": ["available", "pending", "sold"]
          },
          "availableInstances": {
            "type": "integer",
            "format": "int32",
            "examples": [7],
            "exclusiveMaximum": 10,
            "exclusiveMinimum": 1
          }
        },
        "xml": { "name": "Pet" }
      }
    },
    "securitySchemes": {
      "petstore_auth": {
        "type": "oauth2",
        "flows": {
          "implicit": {
            "authorizationUrl": "https://petstore31.swagger.io/oauth/authorize",
            "scopes": {
              "write:pets": "modify pets in your account",
              "read:pets": "read your pets"
            }
          }
        }
      },
      "mutual_tls": { "type": "mutualTLS" },
      "api_key": {
        "type": "apiKey",
        "name": "api_key",
        "in": "header"
      }
    }
  }
}
