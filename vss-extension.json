{
  "manifestVersion": 1,
  "id": "postman-bootstrap",
  "name": "Postman Bootstrap",
  "version": "0.11.0",
  "publisher": "postman-cse",
  "targets": [
    {
      "id": "Microsoft.VisualStudio.Services"
    }
  ],
  "description": "Bootstrap a Postman workspace, API spec, and test collections from an OpenAPI specification.",
  "categories": [
    "Azure Pipelines"
  ],
  "icons": {
    "default": "images/extension-icon.png"
  },
  "files": [
    {
      "path": "ado"
    }
  ],
  "contributions": [
    {
      "id": "postman-bootstrap-task",
      "type": "ms.vss-distributed-task.task",
      "targets": [
        "ms.vss-distributed-task.tasks"
      ],
      "properties": {
        "name": "ado"
      }
    }
  ]
}
